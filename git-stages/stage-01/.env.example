# Режим приложения: development | production | demo
APP_ENV=development

# Режим отладки Django (для production/demo ставить false)
DEBUG=true

# Секретный ключ Django (заменить в реальном окружении!)
SECRET_KEY=change_me_in_real_project

# Разрешённые хосты через запятую
ALLOWED_HOSTS=localhost,127.0.0.1

# Порт запуска (для Docker и скриптов)
APP_PORT=8000

# База данных SQLite (по умолчанию)
DATABASE_URL=sqlite:///db.sqlite3

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS (для production указать конкретные домены)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
